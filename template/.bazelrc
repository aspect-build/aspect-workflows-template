# Curated flag presets generated by bazelrc-preset.bzl (run `tools/repin` to
# regenerate). Kept separate so it can be regenerated without touching this file.
import %workspace%/bazel/preset.bazelrc
{%- if java or kotlin or scala %}
# Pin the Java language level + a hermetic JDK for JVM-language presets. The
# default local_jdk is non-hermetic and (for the bundled headless JDK) is
# missing modules like java.desktop that tools such as ktfmt need.
import %workspace%/bazel/java17.bazelrc
{%- endif %}

# See https://aspect.build/blog/configuring-bazels-downloader
common --downloader_config=bazel/downloader.cfg
{% if javascript %}

# Pass `--skipLibCheck` to every tsc spawn for speed.
# ts_project targets transpile with SWC (transpiler = swc); tsc only
# type-checks and emits .d.ts, so no default-transpiler flag is needed.
common --@aspect_rules_ts//ts:skipLibCheck=always
{% endif %}
{% if python %}

# Select the uv hub's `default` dependency-group (declared in pyproject.toml).
common --@pypi//dep_group=default
# Select the hermetic 3.12 interpreter from @python_interpreters. Its toolchains
# are gated on this flag (target_settings = python_version_is_3_12); without it,
# resolution falls through to a transitively-registered rules_python interpreter.
common --@aspect_rules_py//py/private/interpreter:python_version=3.12
{% endif %}
{% if proto %}

common --@protobuf//bazel/toolchains:prefer_prebuilt_protoc
{% endif %}
{% if stamp %}

# To stamp release builds, run with
# --config=release
common:release --stamp --workspace_status_command=./bazel/workspace_status.sh
{% endif %}

# Load settings & overrides specific to the current user from `user.bazelrc`.
# That file is git-ignored so settings aren't shared with team members. This is
# the last statement in this config so user settings can override flags set
# above. See https://bazel.build/configure/best-practices#bazelrc-file.
try-import %workspace%/user.bazelrc
